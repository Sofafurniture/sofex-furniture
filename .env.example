# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — https://dashboard.stripe.com/apikeys
# Add these to Netlify: Site settings → Environment variables
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Enable Apple Pay, Google Pay, Klarna & Clearpay in:
# https://dashboard.stripe.com/settings/payment_methods

# Site URL (use http://localhost:3000 for local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Official store email — all order & contact notifications
STORE_EMAIL=info@sofexfurniture.co.uk
EMAIL_FROM=Sofex Furniture <info@sofexfurniture.co.uk>

# Transactional email via Resend — https://resend.com
# Verify your domain and add RESEND_API_KEY to Netlify
RESEND_API_KEY=re_...

# Payment test mode — Brooklyn configurator orders charge £1 (set false when live)
PAYMENT_TEST_ENABLED=true
PAYMENT_TEST_PRICE_GBP=1

# Admin panel — change these before going live!
ADMIN_EMAIL=admin@sofex.furniture
ADMIN_PASSWORD=admin123
ADMIN_SECRET=generate-a-long-random-string-here

# Driver accounts (company delivery drivers only)
DRIVER_1_EMAIL=driver1@sofex.furniture
DRIVER_1_PASSWORD=driver123
DRIVER_1_NAME=Driver One
DRIVER_2_EMAIL=driver2@sofex.furniture
DRIVER_2_PASSWORD=driver123
DRIVER_2_NAME=Driver Two
